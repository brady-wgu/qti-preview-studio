{
  "name": "qti-preview-studio",
  "productName": "QTI Preview Studio",
  "version": "1.0.0",
  "description": "Offline QTI (v1.2 / v2.1) item bank previewer -- generates ITEM_PREVIEW and PRINT_PREVIEW HTML from QTI archives.",
  "main": "src/main/main.js",
  "author": "Your Organization",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test:core": "node test/run-against-exemplars.js",
    "test:ui": "node test/smoke-test-renderer.js",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourorg.qtipreviewstudio",
    "productName": "QTI Preview Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "lib/**/*",
      "assets/**/*",
      "docs/**/*",
      "package.json"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.education",
      "target": ["dmg", "zip"],
      "icon": "build-resources/icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "build-resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
